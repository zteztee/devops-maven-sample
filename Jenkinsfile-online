pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: maven
    image: kubesphere/builder-maven:v3.1.0
    command: ['cat']
    tty: true
'''
    }
  }

  parameters {
    string(name:'TAG_NAME',defaultValue: '',description:'')
  }

  environment {
    DOCKER_CREDENTIAL_ID = 'dockerhub-id'
  }

  stages {
    stage ('checkout scm') {
      steps {
        checkout(scm)
      }
    }

    stage ('unit test') {
      steps {
        container('maven') {
          sh 'mvn clean test'
        }
      }
    }

    stage ('build & push') {
      steps {
        container('maven') {
          sh 'mvn clean package -DskipTests'
          
          // 👇 我已经帮你写死了！不会再出现双斜杠！
          sh 'docker build -f Dockerfile-online -t docker.io/zte020415/devops-maven-sample:SNAPSHOT-$BRANCH_NAME-$BUILD_NUMBER .'
          
          withCredentials([usernamePassword(
            passwordVariable: 'DOCKER_PASSWORD',
            usernameVariable: 'DOCKER_USERNAME',
            credentialsId: "dockerhub-id"
          )]) {
            sh 'echo "$DOCKER_PASSWORD" | docker login docker.io -u "$DOCKER_USERNAME" --password-stdin'
            sh 'docker push docker.io/zte020415/devops-maven-sample:SNAPSHOT-$BRANCH_NAME-$BUILD_NUMBER'
          }
        }
      }
    }
  }
}

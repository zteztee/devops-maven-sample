pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: maven
    image: kubesphere/builder-base:v4.2.1
    command: ['cat']
    tty: true

  - name: kaniko
    image: registry.aliyuncs.com/kubesphere/kaniko-executor:v1.9.1
    command: ['cat']
    tty: true
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker/

  volumes:
  - name: docker-config
    secret:
      secretName: dockerhub-id
'''
    }
  }

  stages {
    stage('checkout scm') {
      steps {
        sh 'git config --global http.sslVerify false && git config --global https.sslVerify false'
        checkout(scm)
      }
    }

    stage('build') {
      steps {
        container('maven') {
          sh 'mvn clean package -DskipTests'
        }
      }
    }

    stage('kaniko push') {
      steps {
        container('kaniko') {
          sh '''
            /kaniko/executor \
              --context ./ \
              --dockerfile Dockerfile-online \
              --destination docker.io/zte020415/devops-maven-sample:SNAPSHOT-$BRANCH_NAME-$BUILD_NUMBER
          '''
        }
      }
    }
  }
}

pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:v1.23.1
    command: ['sleep']
    args: ['99d']
'''
    }
  }
  stages {
    stage('check') {
      steps {
        container('kaniko') {
          sh '/kaniko/executor --version'
        }
      }
    }
  }
}

pipeline {
  agent {
    kubernetes {
      yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: maven
    image: kubesphere/builder-base:v4.2.1
    command: ['cat']
    tty: true
'''
    }
  }

  parameters {
    string(name:'TAG_NAME',defaultValue: '',description:'')
  }

  environment {
    DOCKER_CREDENTIAL_ID = 'dockerhub-id'
    REGISTRY = 'docker.io'
    DOCKERHUB_NAMESPACE = 'zteztee'
    APP_NAME = 'devops-maven-sample'
  }

  options {
    setGitHubCommitStatus(false)
  }

  stages {
    stage('clone code') {
      steps {
        container('maven') {
          sh '''
            git config --global http.sslVerify false
            git config --global https.sslVerify false
            export GIT_SSL_NO_VERIFY=true
            
            rm -rf ./*
            git clone https://github.com/zteztee/devops-maven-sample.git .
            git checkout v4.1.0-sonarqube
          '''
        }
      }
    }

    stage('unit test') {
      steps {
        container('maven') {
          sh 'mvn clean package -DskipTests'
        }
      }
    }

    stage('build & push with kaniko') {
      steps {
        container('maven') {
          withCredentials([usernamePassword(usernameVariable: 'USER', passwordVariable: 'PWD', credentialsId: 'dockerhub-id')]) {
            sh '''
              mkdir -p /kaniko/.docker
              echo "{\\\"auths\\\":{\\\"${REGISTRY}\\\":{\\\"auth\\\":\\\"$(echo -n $USER:$PWD | base64 -w0)\\\"}}}" > /kaniko/.docker/config.json
            '''

            sh '''
              /kaniko/executor --context ./ \
              --dockerfile Dockerfile-online \
              --destination ${REGISTRY}/${DOCKERH_NAMESPACE}/${APP_NAME}:SNAPSHOT-${BRANCH_NAME}-${BUILD_NUMBER}
            '''
          }
        }
      }
    }
  }
}
